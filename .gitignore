.DS_Store
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.ty_cache/
# Python build artifacts (`uv build` output); the project declares its license
# files (LICENSE + NOTICE) in pyproject.toml but isn't published as a package, so
# these stay uncommitted.
build/
dist/
*.egg-info/

# Chart exports the app generates, not source: the Static-PNG "Download PNG"
# button saves `<type>-chart.png` (e.g. `bubble-chart.png`).
*-chart.png

# Editor config is per-developer, not committed.
.vscode/
.idea/

# .streamlit/config.toml is committed (theme + dev settings); ignore only secrets.
.streamlit/secrets.toml

# .claude/ holds Claude Code project config: settings.json and the hooks/ scripts
# are committed shared config; only the per-developer local overrides are ignored.
.claude/settings.local.json
